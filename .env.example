APP_NAME=Bank Statement Portal
HOST=0.0.0.0
PORT=8000
SECRET_KEY=replace-this-in-production
SESSION_COOKIE_NAME=bank_portal_session
SESSION_TTL_HOURS=24
SESSION_SECURE_COOKIE=false

# Local default uses SQLite automatically if DATABASE_URL is omitted.
# Example Postgres connection:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/transaction_db

DB_HOST=localhost
DB_PORT=5432
DB_NAME=transaction_db
DB_USER=postgres
DB_PASSWORD=postgres